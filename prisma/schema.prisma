generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MASTER_ADMIN
  TEAM_MEMBER
  DISTRIBUTOR
}

enum Rank {
  DISTRIBUTOR
  BRONZE
  SILVER
  GOLDEN
  DIAMOND
  SUPER_DIAMOND
  PLATINUM
  CENTENNIAL
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  phone       String?      @unique
  password    String
  role        Role         @default(DISTRIBUTOR)
  memberId    String?      @unique
  rank        Rank         @default(DISTRIBUTOR)
  status      MemberStatus @default(ACTIVE)
  joiningDate DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  // KYC & Identity
  panNumber    String?
  aadhaarNumber String?
  address      String?

  // Bank / Payout details
  bankAccount  String?
  ifscCode     String?
  upiId        String?
  bankName     String?

  sponsorId    String?
  sponsor      User?  @relation("MLMTree", fields: [sponsorId], references: [id])
  downline     User[] @relation("MLMTree")

  managedBy    String?
  manager      User?  @relation("TeamManagement", fields: [managedBy], references: [id])
  managedUsers User[] @relation("TeamManagement")

  salesEntries  Sale[]             @relation("MemberSales")
  enteredSales  Sale[]             @relation("EnteredBySales")
  piEntries     PIEntry[]
  biEntries     BIEntry[]
  payouts       PayoutRecord[]
  biPayouts     BiPayoutRecord[]
  commissions   CommissionRecord[] @relation("EarnedCommissions")
  rankHistory   RankHistory[]

  @@map("users")
}

model Sale {
  id          String    @id @default(cuid())
  memberId    String
  member      User      @relation("MemberSales", fields: [memberId], references: [id])
  enteredById String
  enteredBy   User      @relation("EnteredBySales", fields: [enteredById], references: [id])
  amount      Float
  month       Int
  year        Int
  invoiceUrl  String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  saleItems   SaleItem[]

  @@map("sales")
}

model Product {
  id        String     @id @default(cuid())
  name      String
  mrp       Float
  piRate    Float      @default(10)  // PI % of MRP — seller's own PI
  biRate    Float      @default(1)   // BI % of MRP — each upline member earns this fixed % per sale
  piDirect  Float      @default(0)   // unused
  piUpline  Float      @default(0)   // PI % of MRP — each upline member earns this fixed % per sale
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  saleItems SaleItem[]

  @@map("products")
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  mrpAtSale Float

  @@map("sale_items")
}

enum CommissionType {
  BUSINESS
  PI
  BI
}

model CommissionRecord {
  id           String         @id @default(cuid())
  memberId     String
  member       User           @relation("EarnedCommissions", fields: [memberId], references: [id])
  saleId       String
  fromMemberId String
  month        Int
  year         Int
  type         CommissionType
  amount       Float
  depth        Int
  createdAt    DateTime       @default(now())

  @@map("commission_records")
}

model PiRate {
  id           String   @id @default(cuid())
  month        Int
  year         Int
  ratePerPoint Float
  createdAt    DateTime @default(now())

  @@unique([month, year])
  @@map("pi_rates")
}

model PayoutRecord {
  id          String   @id @default(cuid())
  memberId    String
  member      User     @relation(fields: [memberId], references: [id])
  month       Int
  year        Int
  salaryAmount    Float    @default(0)
  piAmount        Float    @default(0)
  biAmount        Float    @default(0)
  totalAmount     Float    @default(0)
  paymentMode     String?
  transactionRef  String?
  notes           String?
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([memberId, month, year])
  @@map("payout_records")
}

model PIEntry {
  id        String   @id @default(cuid())
  memberId  String
  member    User     @relation(fields: [memberId], references: [id])
  amount    Float
  month     Int
  year      Int
  notes     String?
  createdAt DateTime @default(now())

  @@map("pi_entries")
}

model BIEntry {
  id        String   @id @default(cuid())
  memberId  String
  member    User     @relation(fields: [memberId], references: [id])
  amount    Float
  period    String
  notes     String?
  createdAt DateTime @default(now())

  @@map("bi_entries")
}

model BiPayoutRecord {
  id             String   @id @default(cuid())
  memberId       String
  member         User     @relation(fields: [memberId], references: [id])
  period         String
  fromMonth      Int
  fromYear       Int
  toMonth        Int
  toYear         Int
  amount         Float
  paymentMode    String?
  transactionRef String?
  notes          String?
  paidAt         DateTime @default(now())
  createdAt      DateTime @default(now())

  @@map("bi_payout_records")
}

model BiConfig {
  id        String   @id @default(cuid())
  baseRate  Float    @default(1.0)
  updatedAt DateTime @updatedAt

  @@map("bi_config")
}

model IncentiveLevelConfig {
  id        String   @id @default(cuid())
  type      String   // "PI" or "BI"
  level     Int      // 1–8 (depth in upline chain, 1 = direct sponsor)
  pct       Float    // % of total PI/BI pool this level receives
  updatedAt DateTime @updatedAt

  @@unique([type, level])
  @@map("incentive_level_config")
}

model RankHistory {
  id        String   @id @default(cuid())
  memberId  String
  member    User     @relation(fields: [memberId], references: [id])
  oldRank   Rank
  newRank   Rank
  month     Int
  year      Int
  reason    String?
  createdAt DateTime @default(now())

  @@map("rank_history")
}
